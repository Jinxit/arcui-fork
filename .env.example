# Copy to .env and fill in real values. .env is gitignored; this template is committed.
#
# AGENTS_MCP_TOKEN authenticates this repo's Claude Code session against the
# eloylp/agents daemon's fleet-management MCP server (declared in .mcp.json).
# Create the token in the daemon dashboard at Config -> Authentication
# (plaintext is shown once). Revoke from the same page.
#
# The MCP token is read from the environment via ${AGENTS_MCP_TOKEN} expansion
# in .mcp.json, so it must be present in the shell that launches `claude`
# (e.g. `set -a; . ./.env; set +a` before starting, or export it in your shell).

AGENTS_MCP_TOKEN=agents_your_token_here
